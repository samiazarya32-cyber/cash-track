function money(n) {
  return n.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function formatMoney(n, currencyCode) {
  const c = CURRENCIES[currencyCode] || CURRENCIES.USD;
  return `${c.symbol} ${money(n)}`;
}

